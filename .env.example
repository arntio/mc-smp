# Copy to .env on the server host and fill in. Used by compose.prod.yaml.
# Do NOT commit the real .env.

# ── Required secrets ─────────────────────────────────────────────────────────
# RCON password — any strong random string; shared by the server and backup.
RCON_PASSWORD=change-me

# Cloudflare R2 (S3-compatible) backup target.
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET=mc-smp-backups
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# ── Optional tunables (uncomment to override the defaults shown) ──────────────
#INIT_MEMORY=2G
#MAX_MEMORY=10G
#MOTD=\u00A76Snake SMP\u00A7r\n\u00A77Survival Vanilla
#DIFFICULTY=hard
#ALLOW_FLIGHT=true
#ENABLE_COMMAND_BLOCK=true
#SPAWN_PROTECTION=0
#VIEW_DISTANCE=32
#SEED=-8884663891400755025
#ENABLE_WHITELIST=true
